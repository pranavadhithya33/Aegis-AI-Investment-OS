# Aegis AI - Environment Variables Example

# App Environment (dev or prod)
ENV=dev
LOG_LEVEL=INFO

# Database Connection (Optional, defaults to sqlite:///PROJECT_ROOT/data/aegis.db)
# DATABASE_URL=sqlite:///c:/Users/user/OneDrive/Desktop/finance/data/aegis.db

# Gemini API Key (Primary AI Agent model)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (Fallback AI Agent model)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API Key (Alternative AI provider)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Ollama Host (Offline Fallback AI model)
OLLAMA_HOST=http://localhost:11434

# FRED API Key (Macro Economics Data - Free from St. Louis Fed)
FRED_API_KEY=your_fred_api_key_here
